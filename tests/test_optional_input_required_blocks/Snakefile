"""
Missing required input still blocks workflow.

Scenario:
- one required count file is missing (counts_required.json)
- optional files exist (counts_opt_000.json)

Expected:
- fails
- letter_counts.json is not created
- partial continuation happens only for optional inputs; required missing = error
"""

rule all:
    input:
        "letter_counts.json"


rule merge_counts:
    input:
        required="counts_required.json",
        optional_counts=optional(["counts_opt_000.json"])
    output:
        "letter_counts.json"
    run:
        import json
        from pathlib import Path

        merged = {}

        data = json.loads(Path(input.required).read_text())
        for key, value in data.items():
            merged[key] = merged.get(key, 0) + value

        for counts_file in input.optional_counts:
            data = json.loads(Path(counts_file).read_text())
            for key, value in data.items():
                merged[key] = merged.get(key, 0) + value

        Path(output[0]).write_text(json.dumps(merged, sort_keys=True))
