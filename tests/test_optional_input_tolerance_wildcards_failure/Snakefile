"""
Optional input tolerance failure scenario (with wildcards):
- counts_000.json and counts_001.json exist.
- counts_002.json, counts_003.json, and counts_004.json are missing and
    tolerance=0.5 only allows two missing inputs.
"""

rule all:
    input:
        "letter_counts.json"

rule merge_counts:
    input:
        counts=optional(expand("counts_00{i}.json", i=range(5)), tolerance=0.5)
    output:
        "letter_counts.json"
    run:
        import json
        from pathlib import Path

        merged = {}
        for counts_file in input.counts:
            data = json.loads(Path(counts_file).read_text())
            for key, value in data.items():
                merged[key] = merged.get(key, 0) + value

        Path(output[0]).write_text(json.dumps(merged, sort_keys=True))
