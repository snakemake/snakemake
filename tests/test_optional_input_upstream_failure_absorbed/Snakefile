"""
Optional input absorbs upstream failure when tolerance allows it.

Scenario:
- 3 chunks
- count_letters for chunk 002 exits with code 1 (raises exception)
- counts_002.json is missing
- merge_counts uses optional(expand(...)) with default tolerance (1.0)

Expected:
- succeeds (1/3 missing = 33% <= 100% tolerance)
- letter_counts.json contains only chunks 000 and 001: {"a": 2, "b": 3}
- failure of count_letters chunk 002 is absorbed by the optional dep
"""

chunks = ["000", "001", "002"]


rule all:
    input:
        "letter_counts.json"


rule count_letters:
    output:
        "counts_{chunk}.json"
    run:
        import json
        from pathlib import Path

        if wildcards.chunk == "002":
            raise Exception("Simulated failure for chunk 002 (exit code 1)")

        data = {"000": {"a": 2}, "001": {"b": 3}}.get(wildcards.chunk, {})
        Path(output[0]).write_text(json.dumps(data))


rule merge_counts:
    input:
        counts=optional(expand("counts_{chunk}.json", chunk=chunks))
    output:
        "letter_counts.json"
    run:
        import json
        from pathlib import Path

        merged = {}
        for counts_file in input.counts:
            data = json.loads(Path(counts_file).read_text())
            for key, value in data.items():
                merged[key] = merged.get(key, 0) + value

        Path(output[0]).write_text(json.dumps(merged, sort_keys=True))
