"""
Optional missing input is visible in job metadata/logging.
The workflow completes with all inputs marked as optional but one missing.

Scenario:
- one optional input out of three missing (counts_002.json)
- pre-placed files: counts_000.json and counts_001.json

Expected:
- succeeds
- logs/report indicate that one optional input (counts_002.json) was skipped
"""

rule all:
    input:
        "letter_counts.json"


rule merge_counts:
    input:
        counts=optional(["counts_000.json", "counts_001.json", "counts_002.json"])
    output:
        "letter_counts.json"
    run:
        import json
        from pathlib import Path

        merged = {}
        for counts_file in input.counts:
            data = json.loads(Path(counts_file).read_text())
            for key, value in data.items():
                merged[key] = merged.get(key, 0) + value

        Path(output[0]).write_text(json.dumps(merged, sort_keys=True))
