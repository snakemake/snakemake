"""
impatient=False waits for all upstream jobs to complete before checking tolerance.

Scenario:
- 3 chunks: 000 and 001 succeed, 002 raises an exception
- merge_counts uses optional(expand(...), tolerance=0.4) (impatient=False, the default)
- 1/3 missing = 33.3% <= 40% tolerance, so workflow should succeed

Expected:
- succeeds
- letter_counts.json contains only chunks 000 and 001: {"a": 2, "b": 3}
"""

chunks = ["000", "001", "002"]


rule all:
    input:
        "letter_counts.json"


rule count_letters:
    output:
        "counts_{chunk}.json"
    run:
        import json
        from pathlib import Path

        if wildcards.chunk == "002":
            raise Exception("Simulated failure for chunk 002")

        data = {"000": {"a": 2}, "001": {"b": 3}}.get(wildcards.chunk, {})
        Path(output[0]).write_text(json.dumps(data))


rule merge_counts:
    input:
        counts=optional(expand("counts_{chunk}.json", chunk=chunks), tolerance=0.4)
    output:
        "letter_counts.json"
    run:
        import json
        from pathlib import Path

        merged = {}
        for counts_file in input.counts:
            data = json.loads(Path(counts_file).read_text())
            for key, value in data.items():
                merged[key] = merged.get(key, 0) + value

        Path(output[0]).write_text(json.dumps(merged, sort_keys=True))
